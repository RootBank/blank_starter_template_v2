{
  "extends": "./tsconfig.json",
  "include": ["./code/**/*"],
  "exclude": ["./__tests__/**/*"],
  "compilerOptions": {
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "commonjs",
    "target": "es2022",
    "moduleResolution": "node",
    "esModuleInterop": true
  }
}
